      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by(cluster, le) (rate(ovnkube_node_cni_request_duration_seconds_bucket{cluster=~\"$cluster\",command=\"ADD\"}[10m]))) > 0",
          "range": true,
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
