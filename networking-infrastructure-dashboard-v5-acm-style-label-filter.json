{
  "uid": "networking-infrastructure-acm",
  "title": "Networking / Infrastructure",
  "tags": [
    "openshift",
    "networking",
    "infrastructure",
    "ovn-kubernetes",
    "acm"
  ],
  "timezone": "browser",
  "schemaVersion": 30,
  "version": 5,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Network Configuration",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Changes Per Second",
      "datasource": "$datasource",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (rate(ovnkube_node_cni_request_duration_seconds_count{cluster=~\"$cluster\"}[10m]))",
          "range": true,
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors",
      "datasource": "$datasource",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cluster) (ovnkube_node_cni_request_duration_seconds_count{cluster=~\"$cluster\",err!=\"false\"}) / sum by (cluster) (ovnkube_node_cni_request_duration_seconds_count{cluster=~\"$cluster\"})",
          "range": true,
          "legendFormat": "{{cluster}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 4
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latency on Pod Creation, P99",
      "datasource": "$datasource",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 1
